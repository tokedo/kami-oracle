# Copy to .env and fill in. .env is gitignored.

# Public Yominet RPC. Default works; override if you run your own.
YOMINET_RPC_URL=https://jsonrpc-yominet-1.anvil.asia-southeast.initia.xyz

# DuckDB file location (relative to repo root).
KAMI_ORACLE_DB_PATH=db/kami-oracle.duckdb

# Rolling window, in days. Stage 1 runs at 7 days while we investigate the
# data we're actually collecting (see memory/decoder-notes.md
# "action-mix divergence"); may extend to 28 once the registry-snapshot
# fix lands. Do not change without reviewing the module spec in
# blocklife-ai/context/modules/kami-oracle.md.
KAMI_ORACLE_WINDOW_DAYS=7

# Polling cadence for the continuous tail, in seconds.
# Yominet produces blocks every ~1–2s; anything under ~5s is overkill.
KAMI_ORACLE_POLL_INTERVAL_S=3

# Log level: DEBUG / INFO / WARNING / ERROR
KAMI_ORACLE_LOG_LEVEL=INFO

# Bearer token required on all /sql, /kami, /operator, /actions,
# /nodes, /registry routes. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave unset for loopback-only dev; required once binding to
# non-loopback (see KAMI_ORACLE_API_BIND).
KAMI_ORACLE_API_TOKEN=

# HTTP bind address for the co-hosted API. Default is loopback-only.
# Binding to a non-loopback host (0.0.0.0, VPC IP, etc.) also requires
# KAMI_ORACLE_ALLOW_NONLOOPBACK=1 AND KAMI_ORACLE_API_TOKEN set.
KAMI_ORACLE_API_BIND=127.0.0.1:8787

# Deliberate opt-in to bind the API outside loopback. Required (together
# with KAMI_ORACLE_API_TOKEN) before serve.py will accept a non-loopback
# bind. Leave unset for dev; set to 1 on hosts behind a trusted perimeter.
KAMI_ORACLE_ALLOW_NONLOOPBACK=

# Interval between scheduled prune sweeps inside the serve process
# (seconds). Prune deletes rows older than KAMI_ORACLE_WINDOW_DAYS on
# this cadence; no manual `python -m ingester.prune` needed.
KAMI_ORACLE_PRUNE_INTERVAL_S=3600

# Per-token request limit for the public plane, fixed 60-second window.
# Caddy gates network-level abuse; this caps cost-per-token (e.g. one
# Colab notebook hammering /sql in a loop). Bump if a legitimate
# consumer needs more headroom; the cheap reads are O(rows) bounded.
KAMI_ORACLE_RATE_LIMIT_PER_MIN=60
